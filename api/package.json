{
    "name": "api",
    "type": "module",
    "scripts": {
        "dev": "npx tsx watch --env-file=.env src/dev.ts",
        "build": "esbuild --bundle --outfile=./dist/index.js --platform=node --target=node20 ./src/index.ts",
        "zip": "zip -j lambda.zip dist/index.js",
        "update": "aws lambda update-function-code --zip-file fileb://lambda.zip --function-name morivis-api --region ap-northeast-1",
        "deploy": "run-s build zip update"
    },
    "devDependencies": {
        "@types/node": "^25.3.0",
        "esbuild": "^0.21.4",
        "npm-run-all2": "^6.2.0",
        "tsx": "^4.21.0"
    },
    "dependencies": {
        "@hono/node-server": "^1.19.9",
        "@hono/swagger-ui": "^0.5.3",
        "@hono/zod-openapi": "^1.2.2",
        "hono": "^4.12.1",
        "pmtiles": "^4.3.0"
    }
}
